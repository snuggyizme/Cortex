{
  "scopeName": "source.cortex",
  "fileTypes": ["cortex"],
  "patterns": [
    {
      "name": "keyword.control.cortex",
      "match": "^\\s*(\\w+)"
    },
    {
      "name": "comment.line.at.cortex",
      "match": "^[ \\t]*@.*"
    },
    {
      "name": "string.quoted.double.cortex",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "constant.numeric.cortex",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    }
  ]
}